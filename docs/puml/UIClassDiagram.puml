skinparam ranksep 150
skinparam classAttributeIconSize 0
skinparam CircledCharacterFontSize 0
skinparam CircledCharacterRadius 0
skinparam class {
    BackgroundColor White
    BorderColor Black
    ArrowColor Black
}

class ErrorUi
class CategoryUi
class DeadlineUi




class EventUi
class TaskUi
class LimitUi
class CommandHelp

class GeneralUi
ErrorUi -[hidden]- GeneralUi
