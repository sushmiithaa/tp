@startuml TaskValidatorSequenceDiagram


skinparam sequenceArrowThickness 2
skinparam roundcorner 10
skinparam DefaultFontSize 24
skinparam ArrowFontSize 24

title TaskValidator Sequence Diagram

participant ":CommandParser" as CP

-> CP : add sentence \n(description, dateTime, catIdx)
activate CP

create "AC:AddCommand" as AC
CP -> AC : new AddCommand(sentence)
activate AC
AC --> CP
deactivate AC
<-- CP
deactivate CP


-> AC : execute(container)
activate AC
participant ":TaskValidator" as TV
participant ":CategoryList" as CL
participant ":Category" as CAT
participant ":EventList" as EL
note over CP,EL : This sequence diagram covers the happy path only.

'─── Step 1: Unique Task ───────────────────────────────────
AC -> TV : validateUniqueTask(categories, catIdx, description)
activate TV

TV -> CL : getCategory(catIdx)
activate CL
CL --> TV : targetCat
deactivate CL

TV -> CAT : getTodoList().contains(description)
activate CAT
CAT --> TV : existsAsTodo
deactivate CAT

TV -> CAT : getDeadlineList().contains(description)
activate CAT
CAT --> TV : existsAsDeadline
deactivate CAT

TV -> CAT : getEventList().contains(description)
activate CAT
CAT --> TV : existsAsEvent
deactivate CAT

TV --> AC : validation passed
deactivate TV

'─── Step 2: Workload ──────────────────────────────────────
AC -> TV : validateWorkload(categories, dateTime, maxTasks)
activate TV

note over TV : totalTimedTasks = 0\ntargetDate = dateTime.toLocalDate()

loop for each Category in CategoryList
    TV -> CAT : getDeadlineList()
    activate CAT
    loop for each Deadline
        CAT --> TV : deadline.getBy().toLocalDate()
        deactivate CAT
        TV -> TV : if equals targetDate, totalTimedTasks++
    end

    TV -> CAT : getEventList()
    activate CAT
    loop for each Event
        CAT --> TV : event.getFrom().toLocalDate()
        deactivate CAT
        TV -> TV : if equals targetDate, totalTimedTasks++
    end
    deactivate CAT
end

TV --> AC : validation passed
deactivate TV

'─── Step 3: Overlap (Events only) ────────────────────────
AC -> TV : validateNoOverlap(existingEvents, start, end)
activate TV

loop for each Event in existingEvents
    TV -> EL : get(i) → existing Event
    activate EL
    EL --> TV : existing.getFrom(), existing.getTo()
    deactivate EL
end

TV --> AC : all validations passed
deactivate TV

 <-- AC : task added successfully
deactivate AC

@enduml