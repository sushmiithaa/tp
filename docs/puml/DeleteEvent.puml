@startuml DeleteEvent

skinparam sequenceArrowThickness 2
skinparam DefaultFontSize 28
skinparam ArrowFontSize 24
skinparam roundcorner 10

title Delete Event (Mapping-Based Deletion)

participant ":CommandParser" as CP
-> CP : parse("delete event ...")
activate CP
create "command:DeleteCommand" as DC
CP -> DC : new
activate DC
DC --> CP :
deactivate DC
CP -->[ : Command
deactivate CP

-> DC : execute(container)
activate DC
participant ":CategoryList" as CL
participant ":Category" as CAT
participant ":EventList" as EL
participant ":GeneralUI" as UI
participant ":CommandSupport" as CS
participant ":Storage" as STORE

DC -> CL : getCurrentView()
activate CL
CL --> DC : return view
    DC -> CL : getActiveDisplayMap()
    CL --> DC : Map<Integer, List<EventReference>>

    note right of DC
    Uses UI index to retrieve EventReference
    from category-specific list
    end note

    DC -> DC : ref = categoryMap.get(uiIndex)

    DC -> CL : getEvent(ref.categoryIndex, \n ref.eventIndex)
    CL --> DC : Event
        DC -> CL : deleteEvent(ref.categoryIndex, \n ref.eventIndex)
        CL -> CAT : deleteEvent(eventIndex)
        activate CAT
        CAT -> EL : remove(eventIndex)
        activate EL
        EL --> CAT
        deactivate EL
        CAT --> CL
        deactivate CAT
        CL --> DC

        DC -> UI : print success message
        activate UI
        UI --> DC
        deactivate UI
        DC -> CS : saveData(container)
        activate CS
        CS -> STORE : save(categories)
        activate STORE
        STORE --> CS
        deactivate STORE
        CS --> DC
        deactivate CS
        DC -> CL : refreshCalendar(categories, calendar)
        CL --> DC
        deactivate CL
        DC -->[ : show success message
        deactivate DC

@enduml

